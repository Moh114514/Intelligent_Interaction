{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intelligent-interaction.local/contracts/events.schema.json",
  "title": "AgentEvent",
  "type": "object",
  "additionalProperties": false,
  "required": ["type", "version", "session_id", "request_id", "timestamp", "data"],
  "properties": {
    "type": {
      "type": "string",
      "enum": ["client.message", "agent.state", "assistant.delta", "assistant.message", "tool.confirmation_required", "tool.confirmation_response", "tool.result", "request.cancel", "request.cancelled", "diagnostics.echo.request", "diagnostics.echo.response", "backend.status", "error"]
    },
    "version": { "const": "1.0" },
    "session_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "minLength": 1 },
    "timestamp": { "type": "string", "format": "date-time" },
    "data": { "type": "object" }
  },
  "$defs": {
    "characterId": { "type": "string", "enum": ["BLACK", "WHITE", "SOLDIER"] },
    "clientMessageData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content", "character_id"],
      "properties": {
        "content": { "type": "string", "minLength": 1 },
        "character_id": { "$ref": "#/$defs/characterId" },
        "interaction_type": { "type": "string", "enum": ["message", "greeting", "feed", "sing"], "default": "message" }
      }
    },
    "agentStateData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state"],
      "properties": { "state": { "$ref": "agent-states.json" } }
    },
    "assistantDeltaData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["delta"],
      "properties": { "delta": { "type": "string", "minLength": 1 } }
    },
    "assistantMessageData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["content"],
      "properties": { "content": { "type": "string", "minLength": 1 } }
    },
    "toolConfirmationRequiredData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmation_id", "tool_call_id", "tool_name", "risk_level", "summary", "expires_at"],
      "properties": {
        "confirmation_id": { "type": "string", "minLength": 1 },
        "tool_call_id": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "risk_level": { "const": "L2" },
        "summary": { "type": "string", "minLength": 1 },
        "expires_at": { "type": "string", "format": "date-time" },
        "details": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "target": { "type": "string" },
            "operation": { "type": "string", "enum": ["search", "read", "create", "replace", "clipboard", "remember", "update", "forget"] },
            "content": { "type": ["string", "null"] },
            "content_length": { "type": ["integer", "null"], "minimum": 0 },
            "will_create_backup": { "type": "boolean" }
          }
        }
      }
    },
    "toolConfirmationResponseData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmation_id", "approved"],
      "properties": {
        "confirmation_id": { "type": "string", "minLength": 1 },
        "approved": { "type": "boolean" }
      }
    },
    "toolResultData": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tool_call_id", "tool_name", "status", "summary"],
      "properties": {
        "tool_call_id": { "type": "string", "minLength": 1 },
        "tool_name": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["succeeded", "denied", "failed", "timed_out", "cancelled"] },
        "summary": { "type": "string", "minLength": 1 }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "type": { "const": "client.message" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/clientMessageData" } } }
    },
    {
      "if": { "properties": { "type": { "const": "agent.state" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/agentStateData" } } }
    },
    {
      "if": { "properties": { "type": { "const": "assistant.delta" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/assistantDeltaData" } } }
    },
    {
      "if": { "properties": { "type": { "const": "assistant.message" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/assistantMessageData" } } }
    },
    {
      "if": { "properties": { "type": { "const": "tool.confirmation_required" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/toolConfirmationRequiredData" } } }
    },
    {
      "if": { "properties": { "type": { "const": "tool.confirmation_response" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/toolConfirmationResponseData" } } }
    },
    {
      "if": { "properties": { "type": { "const": "tool.result" } } },
      "then": { "properties": { "data": { "$ref": "#/$defs/toolResultData" } } }
    }
  ]
}
