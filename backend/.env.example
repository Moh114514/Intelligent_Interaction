LLM_API_KEY=YOUR_DEEPSEEK_API_KEY
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
LLM_TIMEOUT_SECONDS=30
LLM_MAX_HISTORY_MESSAGES=20

AGENT_MAX_TOOL_STEPS=5
TOOL_TIMEOUT_SECONDS=10
TOOL_CONFIRMATION_TIMEOUT_SECONDS=30
# TOOL_SHARED_ROOT=C:/Users/YOUR_NAME/Documents/Garfield Chat Shared

# Speech provider: volcengine (default) or xunfei
SPEECH_PROVIDER=volcengine
SPEECH_TIMEOUT_SECONDS=30
SPEECH_AUDIO_TTL_SECONDS=300

# Volcengine credentials. auto prefers X-Api-Key, then falls back to the
# APP ID + Access Token credentials shown by the old Doubao Speech console.
VOLCENGINE_AUTH_MODE=auto
# New console / Agent Plan:
# VOLCENGINE_SPEECH_API_KEY=YOUR_VOLCENGINE_X_API_KEY
# Old console (Secret Key is not required by these ASR/TTS endpoints):
VOLCENGINE_APP_ID=YOUR_VOLCENGINE_APP_ID
VOLCENGINE_ACCESS_TOKEN=YOUR_VOLCENGINE_ACCESS_TOKEN
SPEECH_VOICE_BLACK=YOUR_BLACK_SPEAKER_ID
SPEECH_VOICE_WHITE=YOUR_WHITE_SPEAKER_ID
SPEECH_VOICE_SOLDIER=YOUR_SOLDIER_SPEAKER_ID
# VOLCENGINE_ASR_RESOURCE_ID=volc.bigasr.auc_turbo
# VOLCENGINE_TTS_RESOURCE_ID=seed-tts-2.0

# Xunfei compatibility provider (used only when SPEECH_PROVIDER=xunfei)
# XUNFEI_APP_ID=YOUR_XUNFEI_APP_ID
# XUNFEI_API_KEY=YOUR_XUNFEI_API_KEY
# XUNFEI_API_SECRET=YOUR_XUNFEI_API_SECRET
